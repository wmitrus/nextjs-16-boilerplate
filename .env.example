# Environment variables
# Use .env.local for local development

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Logger settings
LOG_LEVEL=info
LOG_DIR=logs
LOG_TO_FILE_DEV=false
LOG_TO_FILE_PROD=false
LOGFLARE_API_KEY=
LOGFLARE_SOURCE_TOKEN=
LOGFLARE_SOURCE_NAME=
LOGFLARE_SERVER_ENABLED=false
LOGFLARE_EDGE_ENABLED=false
NEXT_PUBLIC_LOGFLARE_BROWSER_ENABLED=false
NEXT_PUBLIC_LOG_LEVEL=info
LOG_INGEST_SECRET=

# Sentry Error Tracking

# Observability — New Relic APM (free plan supported)
NEW_RELIC_ENABLED=false
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=nextjs-16-boilerplate
# Optional read-only NerdGraph / NRQL debugging scripts:
# US accounts: https://api.newrelic.com/graphql
# EU accounts: https://api.eu.newrelic.com/graphql
NEW_RELIC_NERDGRAPH_API_URL=
NEW_RELIC_USER_API_KEY=
NEW_RELIC_ACCOUNT_ID=
# Optional NR Browser SPA snippet fallback for local/dev compatibility only:
# Vercel deployment env vars are a poor fit for the full copy/paste snippet.
# In deployments, prefer the request-time Node route that generates the loader
# from the New Relic agent instead of storing an 80 KB+ snippet in env vars.
# Prefer NEW_RELIC_BROWSER_SNIPPET_BASE64 for local .env files because raw
# snippets can contain `#`, which dotenv treats as a comment delimiter.
# Use NEW_RELIC_BROWSER_SNIPPET only when your env store preserves the exact
# raw value without dotenv-style parsing.
# Raw JS content source (without <script> tags):
# NR UI → Browser → your app → Application settings → Copy paste installation
# Use Pro+SPA agent type. NEVER commit actual snippet content to this file.
# These env vars are optional and server-side only.
NEW_RELIC_BROWSER_SNIPPET=
NEW_RELIC_BROWSER_SNIPPET_BASE64=

SENTRY_DSN=https://...@....ingest.sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@....ingest.sentry.io/...
SENTRY_AUTH_TOKEN=

# Clerk Authentication (required only when AUTH_PROVIDER=clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Always route through bootstrap after auth so provisioning and onboarding checks run before landing on /users.
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/auth/bootstrap/start?redirect_url=/users
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/auth/bootstrap/start?redirect_url=/users
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/auth/bootstrap/start?redirect_url=/users
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/auth/bootstrap/start?redirect_url=/users
NEXT_PUBLIC_CLERK_WAITLIST_URL=/waitlist

# Server-only secrets (DO NOT commit to version control)
# DATABASE_URL=postgresql://user:password@localhost:5432/db
CHROMATIC_PROJECT_TOKEN=
# Rate Limiting & Upstash
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
API_RATE_LIMIT_REQUESTS=10
API_RATE_LIMIT_WINDOW="60 s"

# Enterprise Security
# Required for trusted server-to-server calls hitting `/api/internal/*`.
# Generate a strong random value locally instead of relying on a shared placeholder.
INTERNAL_API_KEY=
SECURITY_AUDIT_LOG_ENABLED=true
SECURITY_ALLOWED_OUTBOUND_HOSTS=api.clerk.com,clerk.com,clerk.services,clerk-telemetry.com
VERCEL_ENV=development

# CSP allowlists (comma-separated origins)
NEXT_PUBLIC_CSP_SCRIPT_EXTRA=
NEXT_PUBLIC_CSP_CONNECT_EXTRA=
NEXT_PUBLIC_CSP_FRAME_EXTRA=
NEXT_PUBLIC_CSP_IMG_EXTRA=
NEXT_PUBLIC_CSP_FONT_EXTRA=
NEXT_PUBLIC_CSP_STYLE_EXTRA=

# Lighthouse CI
LHCI_SERVER_BASE_URL=https://lighthouse.example.com

# Auth Provider (clerk | authjs | supabase | neon)
#
# Runtime status today:
# - clerk    => implemented
# - authjs   => placeholder only
# - supabase => placeholder only
# - neon     => placeholder only
AUTH_PROVIDER=clerk

# Tenancy Configuration
# TENANCY_MODE: single (default) | personal | org
#   single   — all users share one default tenant (DEFAULT_TENANT_ID required)
#   personal — each user has their own tenant (provisioned on first login)
#   org      — users belong to organizational tenants (TENANT_CONTEXT_SOURCE required)
TENANCY_MODE=single
#
# DEFAULT_TENANT_ID: required when TENANCY_MODE=single (must be a valid UUID)
DEFAULT_TENANT_ID=10000000-0000-4000-8000-000000000001
#
# TENANT_CONTEXT_SOURCE: required when TENANCY_MODE=org
#   provider — org context from auth provider claims (e.g. Clerk Organizations)
#   db       — org context from app-level selector (header or cookie)
# TENANT_CONTEXT_SOURCE=provider
#
# TENANT_CONTEXT_HEADER: header name for active tenant (org/db mode, default: x-tenant-id)
# TENANT_CONTEXT_HEADER=x-tenant-id
#
# TENANT_CONTEXT_COOKIE: cookie name for active tenant (org/db mode, default: active_tenant_id)
# TENANT_CONTEXT_COOKIE=active_tenant_id
#
# FREE_TIER_MAX_USERS: max users per tenant on free plan (default: 5)
# FREE_TIER_MAX_USERS=5
#
# CROSS_PROVIDER_EMAIL_LINKING: controls auto-linking when the same verified email
#   is used across different auth providers (e.g. user switches from Clerk to AuthJS).
#   verified-only (default) — allow linking only when emailVerified=true from the provider
#   disabled               — never auto-link; throw CrossProviderLinkingNotAllowedError
# CROSS_PROVIDER_EMAIL_LINKING=verified-only

# Feature Flags
# FEATURE_FLAG_PROVIDER: selects the active feature-flag adapter.
#   static     (default) — flags are parsed from FEATURE_FLAGS_STATIC; no external service needed
#   db                   — flags are stored in the feature_flags DB table; requires DATABASE_URL
#   growthbook           — delegates to GrowthBook SDK; requires GROWTHBOOK_CLIENT_KEY
# FEATURE_FLAG_PROVIDER=static

# FEATURE_FLAGS_STATIC: comma-separated key=value pairs used by the static adapter.
#   Unknown flag keys default to false. Case-sensitive.
#   The values below power the /feature-flags-demo page out of the box.
FEATURE_FLAGS_STATIC=demo.new-dashboard-ui=true,demo.beta-exports=false,demo.experimental-analytics=true

# GROWTHBOOK_CLIENT_KEY: GrowthBook SDK client key. Required when FEATURE_FLAG_PROVIDER=growthbook.
# GROWTHBOOK_CLIENT_KEY=

# GROWTHBOOK_API_HOST: GrowthBook API/CDN host. Required when FEATURE_FLAG_PROVIDER=growthbook.
#   Default: https://cdn.growthbook.io
# GROWTHBOOK_API_HOST=https://cdn.growthbook.io

# Database
# DB_PROVIDER: persistence provider axis ('drizzle' | 'prisma').
# DB_DRIVER: explicit DB engine axis ('pglite' | 'postgres').
# Defaults: DB_PROVIDER=drizzle, DB_DRIVER=pglite in dev/test, postgres in production.
# DATABASE_URL: required when DB_DRIVER=postgres or NODE_ENV=production.
# For Supabase: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# Local profile A (recommended default): PGlite — zero-config, no container needed
# DB_PROVIDER=drizzle
# DB_DRIVER=pglite
# DATABASE_URL=file:./data/pglite
# migrate/studio: pnpm db:migrate:dev / pnpm db:studio
#
# Local profile B (test Postgres container — test-adjacent, NOT for dev):
# Used by pnpm db:test:* and pnpm test:db:local
# Port 5433, database app_test — start with: pnpm db:test:up
# DB_PROVIDER=drizzle
# DB_DRIVER=postgres
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/app_test
# migrate/studio: pnpm db:test:migrate / pnpm db:test:studio
#
# Local profile C (dev Postgres container — opt-in, full Postgres dev):
# Port 5432, database app_dev — start with: pnpm db:dev:up
# Then: pnpm db:dev:migrate && pnpm db:dev:seed
# DB_PROVIDER=drizzle
# DB_DRIVER=postgres
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/app_dev
# migrate/studio: pnpm db:dev:migrate / pnpm db:dev:studio
DB_PROVIDER=drizzle
DATABASE_URL=file:./data/pglite
DB_DRIVER=pglite

# E2E Testing
E2E_ENABLED=false
# Universal E2E backend mode switch.
# - pglite    => lightweight file-backed scenario mode
# - container => isolated container-backed E2E mode using test DB 5433/app_test
# Use container mode for browser-real auth regression runs.
E2E_BACKEND_MODE=container
# Optional local compose override when container mode is used.
# DB_COMPOSE_ENGINE=podman
# Optional Playwright base URL override.
# PLAYWRIGHT_TEST_BASE_URL=http://localhost:3000
# Prefer .env.e2e / .env.e2e.local for local E2E fixtures and secrets.
# Scenario A: single / returning provisioned user
E2E_CLERK_SINGLE_PROVISIONED_USER_USERNAME=
E2E_CLERK_SINGLE_PROVISIONED_USER_PASSWORD=
# Scenario A: single / first bootstrap new user
E2E_CLERK_SINGLE_NEW_USER_USERNAME=
E2E_CLERK_SINGLE_NEW_USER_PASSWORD=
# Optional auth-regression reusable identity for the incomplete-user path.
# This is only the Clerk identity. The onboarding-incomplete app state should be recreated during the run.
E2E_CLERK_INCOMPLETE_USER_USERNAME=
E2E_CLERK_INCOMPLETE_USER_PASSWORD=
# Scenario B: personal / first bootstrap new personal user
E2E_CLERK_PERSONAL_NEW_USER_USERNAME=
E2E_CLERK_PERSONAL_NEW_USER_PASSWORD=
# Scenario C: org/provider / owner-capable fixture in e2e-org-owner
E2E_CLERK_ORG_PROVIDER_OWNER_USERNAME=
E2E_CLERK_ORG_PROVIDER_OWNER_PASSWORD=
# Scenario C: org/provider / member fixture in e2e-org-member
E2E_CLERK_ORG_PROVIDER_MEMBER_USERNAME=
E2E_CLERK_ORG_PROVIDER_MEMBER_PASSWORD=
# Scenario D: org/db / seeded DB-linked member, must stay bob@example.com
E2E_CLERK_ORG_DB_SEEDED_MEMBER_USERNAME=bob@example.com
E2E_CLERK_ORG_DB_SEEDED_MEMBER_PASSWORD=
# Cross-provider linking negative fixture, must stay alice@example.com and remain unverified
E2E_CLERK_LINK_BLOCKED_UNVERIFIED_USERNAME=alice@example.com
E2E_CLERK_LINK_BLOCKED_UNVERIFIED_PASSWORD=
# Stable org/provider slugs expected by the suite
E2E_CLERK_ORG_PROVIDER_OWNER_SLUG=e2e-org-owner
E2E_CLERK_ORG_PROVIDER_MEMBER_SLUG=e2e-org-member
# Optional OAuth redirect slice. Example: google or github
# E2E_CLERK_OAUTH_PROVIDER=

# Legacy aliases still accepted by e2e/clerk-auth.ts during migration
E2E_CLERK_USER_USERNAME=
E2E_CLERK_USER_PASSWORD=
E2E_CLERK_UNPROVISIONED_USER_USERNAME=
E2E_CLERK_UNPROVISIONED_USER_PASSWORD=
E2E_CLERK_ORG_OWNER_USERNAME=
E2E_CLERK_ORG_OWNER_PASSWORD=
E2E_CLERK_ORG_MEMBER_USERNAME=
E2E_CLERK_ORG_MEMBER_PASSWORD=
E2E_CLERK_UNVERIFIED_EMAIL_USER_USERNAME=
E2E_CLERK_UNVERIFIED_EMAIL_USER_PASSWORD=

VERCEL_PROJECT_ID=
VERCEL_ORG_ID=
