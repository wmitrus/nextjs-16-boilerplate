# Local Podman Leantime development env.
# Copy to `.env.leantime-dev` and keep the copy out of Git.

LEANTIME_URL=http://localhost:8185
LEANTIME_API_KEY=
LEANTIME_RPC_PATH=api/jsonrpc
LEANTIME_SESSION_COOKIE=
LEANTIME_API_TIMEOUT_MS=30000
LEANTIME_DEFAULT_PROJECT_ID=1
LEANTIME_DEFAULT_AUTHOR_ID=2
LEANTIME_DEFAULT_CLIENT_ID=1

LEANTIME_LOCAL_APP_URL=http://localhost:8185
LEANTIME_LOCAL_DEBUG=1
LEANTIME_LOCAL_HTTP_PORT=8185
LEANTIME_LOCAL_IMAGE=docker.io/leantime/leantime:3.7.1
LEANTIME_LOCAL_DB_NAME=leantime
LEANTIME_LOCAL_DB_USER=leantime
LEANTIME_LOCAL_DB_PASSWORD=replace-with-local-dev-password
LEANTIME_LOCAL_DB_ROOT_PASSWORD=replace-with-local-dev-root-password
LEANTIME_LOCAL_SESSION_PASSWORD=replace-with-local-dev-session-password
