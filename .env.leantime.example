# Production / on-prem Leantime automation env.
# Copy to `.env.leantime` and keep the copy out of Git.

LEANTIME_URL=https://leantime.wmitrus.useruno.com
LEANTIME_API_KEY=
LEANTIME_RPC_PATH=api/jsonrpc
LEANTIME_SESSION_COOKIE=
LEANTIME_API_TIMEOUT_MS=30000
LEANTIME_DEFAULT_PROJECT_ID=2
LEANTIME_DEFAULT_AUTHOR_ID=1
LEANTIME_DEFAULT_CLIENT_ID=1

# AutomationApi plugin deploy target.
# Use the dedicated SSH alias from `~/.ssh/config`; set to `s2.hostuno.com`
# only if that host is already configured to use the correct identity.
LEANTIME_DEPLOY_HOST=leantime-hostuno
LEANTIME_DEPLOY_USER=wmitrus
LEANTIME_DEPLOY_SSH_PORT=22
LEANTIME_DEPLOY_ROOT=domains/leantime.wmitrus.useruno.com/public_html/leantime
LEANTIME_PLUGIN_NAME=AutomationApi
LEANTIME_PLUGIN_SOURCE_DIR=leantime-plugins/AutomationApi
LEANTIME_DEPLOY_BACKUP_ROOT=domains/leantime.wmitrus.useruno.com/public_html/leantime/storage/plugin-backups
LEANTIME_DEPLOY_STAGING_ROOT=domains/leantime.wmitrus.useruno.com/public_html/leantime/storage/plugin-deploy-staging
LEANTIME_DEPLOY_MANIFEST_DIR=logs/leantime-plugin-deployments

# Leave unset to use the SSH client default. Use `accept-new` only if you
# deliberately want first-connect host-key bootstrap behavior.
LEANTIME_DEPLOY_STRICT_HOST_KEY_CHECKING=
