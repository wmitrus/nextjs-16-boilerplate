{
  "name": "temp-nextjs-scaffold",
  "version": "1.25.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "predev": "node -e \"try{require('fs').unlinkSync('data/pglite/postmaster.pid')}catch(e){}\"",
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.unit.config.ts --coverage",
    "test:watch": "vitest --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts --coverage",
    "test:all": "vitest run --config vitest.config.ts --coverage",
    "test:db": "vitest run --config vitest.db.config.ts",
    "test:db:ci": "vitest run --config vitest.db.ci.config.ts",
    "test:storybook": "vitest run --project storybook --coverage",
    "test:storybook:watch": "vitest --project storybook",
    "test:storybook:ui": "vitest --project storybook --ui",
    "e2e": "pnpm e2e:scenario:single",
    "e2e:raw": "playwright test",
    "e2e:smoke": "node scripts/e2e/run-scenario.mjs single -- e2e/home.spec.ts e2e/security.spec.ts e2e/auth.spec.ts --project=chromium",
    "e2e:auth": "node scripts/e2e/run-scenario.mjs single -- e2e/auth.spec.ts --project=chromium",
    "e2e:auth-matrix": "pnpm e2e:auth-matrix:phase1 && pnpm e2e:auth-matrix:phase2 && pnpm e2e:auth-matrix:phase3 && pnpm e2e:auth-matrix:phase4 && pnpm e2e:auth-matrix:phase5 && pnpm e2e:auth-matrix:phase6 && pnpm e2e:auth-matrix:phase7",
    "e2e:auth-matrix:phase1": "node scripts/e2e/run-scenario.mjs single -- e2e/auth.spec.ts e2e/provisioning-runtime.spec.ts --project=chromium --reporter=line --grep @auth-matrix-phase1",
    "e2e:auth-matrix:phase2": "pnpm e2e:auth-matrix:phase2:returning-state && pnpm e2e:auth-matrix:phase2:direct-entry",
    "e2e:auth-matrix:phase2:returning-state": "node scripts/e2e/run-scenario.mjs single -- e2e/provisioning-runtime.spec.ts --project=chromium --reporter=line --grep \"single mode: returning login skips onboarding and lands in the app @auth-matrix-phase2|single mode: returning incomplete user sign-in routes back to onboarding before /users settles @auth-matrix-phase2|single mode: direct visit to /users after recreating incomplete state redirects away from /users @auth-matrix-phase2\"",
    "e2e:auth-matrix:phase2:direct-entry": "node scripts/e2e/run-scenario.mjs single -- e2e/provisioning-runtime.spec.ts --project=chromium --reporter=line --grep \"single mode: direct visit to /users after onboarding completion stays allowed @auth-matrix-phase2|single mode: direct visit to /onboarding after onboarding completion redirects to /users @auth-matrix-phase2\"",
    "e2e:auth-matrix:phase2:logged": "PLAYWRIGHT_SERVER_LOG_DIR=logs/playwright/auth-matrix-phase2 node scripts/e2e/run-scenario.mjs single -- e2e/provisioning-runtime.spec.ts --project=chromium --reporter=line --grep @auth-matrix-phase2",
    "e2e:auth-matrix:phase3": "node scripts/e2e/run-scenario.mjs single -- e2e/provisioning-runtime.spec.ts --project=chromium --reporter=line --grep @auth-matrix-phase3",
    "e2e:auth-matrix:phase3:logged": "PLAYWRIGHT_SERVER_LOG_DIR=logs/playwright/auth-matrix-phase3 node scripts/e2e/run-scenario.mjs single -- e2e/provisioning-runtime.spec.ts --project=chromium --reporter=line --grep @auth-matrix-phase3",
    "e2e:auth-matrix:phase4": "node scripts/e2e/run-scenario.mjs single -- e2e/provisioning-runtime.spec.ts --project=chromium --reporter=line --grep @auth-matrix-phase4",
    "e2e:auth-matrix:phase5": "node scripts/e2e/run-scenario.mjs single -- e2e/provisioning-runtime.spec.ts --project=chromium --reporter=line --grep @auth-matrix-phase5",
    "e2e:auth-matrix:phase6": "node scripts/e2e/run-scenario.mjs single -- e2e/provisioning-runtime.spec.ts --project=chromium --reporter=line --grep @auth-matrix-phase6",
    "e2e:auth-matrix:phase7": "PLAYWRIGHT_SERVER_LOG_DIR=logs/playwright/auth-matrix-phase7 node scripts/e2e/run-scenario.mjs single -- e2e/provisioning-runtime.spec.ts --project=chromium --reporter=line --grep @auth-matrix-phase7",
    "e2e:auth-matrix:ci": "pnpm build && E2E_BACKEND_MODE=container pnpm e2e:auth-matrix",
    "e2e:scenario:single": "node scripts/e2e/run-scenario.mjs single -- e2e/provisioning-runtime.spec.ts --project=chromium --grep-invert @auth-matrix",
    "e2e:scenario:personal": "node scripts/e2e/run-scenario.mjs personal",
    "e2e:scenario:org-provider": "node scripts/e2e/run-scenario.mjs org-provider",
    "e2e:scenario:org-db": "node scripts/e2e/run-scenario.mjs org-db",
    "e2e:neg:missing-default-tenant": "node scripts/e2e/run-scenario.mjs single --variant single-missing-default-tenant -- e2e/provisioning-runtime.spec.ts --project=chromium --grep \"missing default tenant\"",
    "e2e:neg:linking-disabled": "node scripts/e2e/run-scenario.mjs single --variant single-linking-disabled -- e2e/provisioning-runtime.spec.ts --project=chromium --grep \"blocked cross-provider linking\"",
    "e2e:neg:free-tier-limit": "node scripts/e2e/run-scenario.mjs single --variant single-free-tier-low -- e2e/provisioning-runtime.spec.ts --project=chromium --grep \"free-tier limit reached\"",
    "e2e:oauth": "node scripts/e2e/run-scenario.mjs single --with-oauth -- e2e/provisioning-runtime.spec.ts --project=chromium --grep OAuth",
    "e2e:full": "pnpm e2e:matrix",
    "e2e:matrix": "pnpm e2e:auth && pnpm e2e:scenario:single && pnpm e2e:scenario:personal && pnpm e2e:scenario:org-provider && pnpm e2e:scenario:org-db",
    "e2e:ui": "node scripts/e2e/run-scenario.mjs single -- --ui",
    "e2e:ci": "pnpm build && pnpm e2e:matrix",
    "prepare": "husky",
    "commit": "cz",
    "skott:check:only": "skott --cwd=src --showCircularDependencies --displayMode=file-tree",
    "depcheck": "depcheck",
    "madge": "madge --circular --extensions ts,tsx src",
    "generate:secret": "node scripts/generate-secret.mjs",
    "env:init": "node scripts/setup-env.mjs",
    "env:check": "node scripts/check-env-consistency.mjs",
    "env:validate": "tsx scripts/validate-env.ts",
    "nr": "tsx scripts/new-relic/cli.ts",
    "nr:query": "tsx scripts/new-relic/query.ts",
    "lt": "node --env-file-if-exists=.env.leantime --import tsx scripts/leantime/cli.ts",
    "lt:dev": "node --env-file-if-exists=.env.leantime-dev --import tsx scripts/leantime/cli.ts",
    "lt:rpc": "node --env-file-if-exists=.env.leantime --import tsx scripts/leantime/rpc.ts",
    "lt:rpc:dev": "node --env-file-if-exists=.env.leantime-dev --import tsx scripts/leantime/rpc.ts",
    "leantime:local:down": "podman-compose --env-file .env.leantime-dev -f compose.leantime-local.yml -p nextjs16-leantime down",
    "leantime:local:logs": "podman-compose --env-file .env.leantime-dev -f compose.leantime-local.yml -p nextjs16-leantime logs -f",
    "leantime:local:ps": "podman-compose --env-file .env.leantime-dev -f compose.leantime-local.yml -p nextjs16-leantime ps",
    "leantime:local:up": "podman-compose --env-file .env.leantime-dev -f compose.leantime-local.yml -p nextjs16-leantime up -d",
    "leantime:plugin:deploy": "node --env-file-if-exists=.env.leantime --import tsx scripts/leantime/deploy-plugin.ts -- --apply",
    "leantime:plugin:plan": "node --env-file-if-exists=.env.leantime --import tsx scripts/leantime/deploy-plugin.ts",
    "codacy:install": "node scripts/codacy-install.mjs",
    "codacy:analyze": "node --env-file-if-exists=.env.codacy scripts/codacy-analyze.mjs",
    "codacy:analyze:sarif": "CODACY_REPORT_MODE=sarif node --env-file-if-exists=.env.codacy scripts/codacy-analyze.mjs",
    "codacy:analyze:findings": "CODACY_REPORT_MODE=findings node --env-file-if-exists=.env.codacy scripts/codacy-analyze.mjs",
    "codacy:analyze:upload": "CODACY_UPLOAD=true node --env-file-if-exists=.env.codacy scripts/codacy-analyze.mjs",
    "chromatic": "chromatic",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "arch:lint": "./scripts/architecture-lint.sh",
    "db:generate": "drizzle-kit generate --config=src/core/db/migrations/config/drizzle.dev.ts",
    "db:migrate:dev": "drizzle-kit migrate --config=src/core/db/migrations/config/drizzle.dev.ts",
    "db:migrate:dev:postgres": "drizzle-kit migrate --config=src/core/db/migrations/config/drizzle.dev.postgres.ts",
    "db:migrate:prod": "drizzle-kit migrate --config=src/core/db/migrations/config/drizzle.prod.ts",
    "db:migrate:prod:local": "node --env-file=.env.production node_modules/drizzle-kit/bin.cjs migrate --config=src/core/db/migrations/config/drizzle.prod.ts",
    "db:migrate:cli": "tsx src/core/db/migrate-cli.ts",
    "db:export:sql": "mkdir -p exports/sql && drizzle-kit export --config=src/core/db/migrations/config/drizzle.dev.ts > exports/sql/schema.sql",
    "db:studio": "drizzle-kit studio --config=src/core/db/migrations/config/drizzle.dev.ts",
    "db:seed": "tsx scripts/db-seed.ts",
    "db:reset:pglite": "node scripts/reset-pglite.mjs",
    "db:dev:up": "node scripts/compose-db-local.mjs up -d dev-db",
    "db:dev:down": "node scripts/compose-db-local.mjs stop dev-db",
    "db:dev:migrate": "node scripts/db-ops.mjs dev migrate",
    "db:dev:seed": "node scripts/db-ops.mjs dev seed",
    "db:dev:studio": "node scripts/db-ops.mjs dev studio",
    "db:dev:reset": "node scripts/db-ops.mjs dev reset",
    "db:test:up": "node scripts/compose-db-local.mjs up -d test-db",
    "db:test:down": "node scripts/compose-db-local.mjs stop test-db",
    "db:test:migrate": "node scripts/db-ops.mjs test migrate",
    "db:test:seed": "node scripts/db-ops.mjs test seed",
    "db:test:studio": "node scripts/db-ops.mjs test studio",
    "db:test:reset": "node scripts/db-ops.mjs test reset",
    "db:all:down": "node scripts/compose-db-local.mjs down",
    "db:local:up": "pnpm db:test:up",
    "db:local:down": "pnpm db:test:down",
    "db:migrate:local": "pnpm db:test:migrate",
    "db:studio:local": "pnpm db:test:studio",
    "test:db:local": "TEST_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/app_test vitest run --config vitest.db.local.config.ts",
    "port:pid": "lsof -ti ",
    "flags:export": "tsx scripts/flags/export.ts",
    "flags:import": "tsx scripts/flags/import.ts",
    "flags:migrate": "tsx scripts/flags/migrate.ts",
    "release": "semantic-release"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{ts,tsx}": [
      "tsc-files --noEmit"
    ],
    "*.{json,css,scss,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@clerk/nextjs": "^6.39.0",
    "@electric-sql/pglite": "^0.3.15",
    "@growthbook/growthbook": "^1.6.5",
    "@logtail/next": "^0.3.1",
    "@logtail/pino": "^0.5.8",
    "@sentry/nextjs": "^10.40.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "@vercel/speed-insights": "^1.3.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "newrelic": "^13.18.0",
    "next": "16.2.3",
    "pino": "^10.3.1",
    "pino-logflare": "^0.5.2",
    "postgres": "^3.4.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@clerk/testing": "^1.14.3",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/eslintrc": "^3.3.4",
    "@playwright/test": "^1.58.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.4",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@storybook/addon-a11y": "^10.2.13",
    "@storybook/addon-docs": "^10.2.13",
    "@storybook/addon-onboarding": "^10.2.13",
    "@storybook/addon-vitest": "^10.2.13",
    "@storybook/nextjs-vite": "^10.2.13",
    "@tailwindcss/postcss": "^4.2.1",
    "@testcontainers/postgresql": "^11.12.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/newrelic": "^9.14.8",
    "@types/node": "^24.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "babel-plugin-react-compiler": "^1.0.0",
    "chromatic": "^15.2.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "depcheck": "^1.4.7",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsonc": "^2.21.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-storybook": "^10.2.13",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "jsonc-eslint-parser": "^2.4.2",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "msw": "^2.12.10",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "semantic-release": "^25.0.3",
    "skott": "^0.35.7",
    "storybook": "^10.2.13",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "tsc-files": "^1.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.56.1",
    "undici": "7.24.0",
    "vite": "^7.3.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "whatwg-fetch": "^3.6.20"
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion": "^5.0.1",
      "@typescript-eslint/utils": "^8.56.1",
      "minimatch": ">=10.2.3",
      "lodash": ">=4.18.0",
      "rollup": "^4.59.0",
      "serialize-javascript": ">=7.0.5",
      "undici": ">=7.24.0",
      "tmp": ">=0.2.4",
      "flatted": ">=3.4.2",
      "effect": ">=3.20.0",
      "picomatch": ">=4.0.4",
      "micromatch>picomatch": "^2.3.2",
      "readdirp>picomatch": "^2.3.2",
      "esbuild": ">=0.25.0",
      "cosmiconfig>yaml": ">=2.8.3",
      "docker-compose>yaml": ">=2.8.3",
      "lint-staged>yaml": ">=2.8.3",
      "brace-expansion": ">=5.0.5",
      "handlebars": ">=4.7.9",
      "lodash-es": ">=4.18.0"
    },
    "onlyBuiltDependencies": [
      "@datadog/pprof",
      "@newrelic/fn-inspect",
      "@newrelic/native-metrics",
      "sharp",
      "unrs-resolver"
    ],
    "patchedDependencies": {
      "depcheck@1.4.7": "patches/depcheck@1.4.7.patch",
      "@storybook/builder-vite@10.2.13": "patches/@storybook__builder-vite@10.2.13.patch"
    }
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
